env_prefix = "cdpfp01"
aws_region = "ap-northeast-1"

deployment_template = "private"

private_network_extensions = false
create_vpc_endpoints       = true

ingress_extra_cidrs_and_ports = {
  cidrs = ["10.99.0.0/24"]
  ports = [22, 443]
}

